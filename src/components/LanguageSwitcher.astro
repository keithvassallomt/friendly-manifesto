---
import { languages, type Lang } from '../i18n/config';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const langEntries = Object.entries(languages) as [Lang, (typeof languages)[Lang]][];
---

{langEntries.length > 1 ? (
  <nav aria-label="Language switcher">
    <ul class="flex gap-2">
      {langEntries.map(([code, { label, flag }]) => (
        <li>
          <a
            href={`/${code}/`}
            class:list={[
              'px-3 py-1 rounded-full text-sm font-medium transition-colors',
              code === lang
                ? 'bg-yellow-400 text-gray-950'
                : 'text-yellow-200 hover:bg-gray-800 hover:text-yellow-50',
            ]}
            aria-current={code === lang ? 'page' : undefined}
          >
            <span aria-hidden="true">{flag}</span> {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
) : (
  <span class="px-3 py-1 rounded-full text-sm font-medium bg-gray-800 text-yellow-300">
    {languages[lang].flag} {languages[lang].label}
  </span>
)}
