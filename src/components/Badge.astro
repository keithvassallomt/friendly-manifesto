---
import { t, type Lang } from '../i18n/config';

interface Props {
  lang: Lang;
  siteUrl?: string;
}

const { lang, siteUrl = 'https://friendlymanifesto.org' } = Astro.props;

const variants = [
  { id: 'colour', label: 'Colour', file: 'badge_colour.svg', bg: 'bg-black' },
  { id: 'black', label: 'Black', file: 'badge_black.svg', bg: 'bg-gray-100' },
  { id: 'white', label: 'White', file: 'badge_white.svg', bg: 'bg-gray-800' },
] as const;
---

<section class="bg-gray-950 border-t border-yellow-400/20">
  <div class="max-w-4xl mx-auto px-6 py-12 text-center">
    <h2 class="text-2xl font-bold text-yellow-300 mb-3">{t(lang, 'badge.heading')}</h2>
    <p class="text-gray-400 mb-8 max-w-2xl mx-auto">{t(lang, 'badge.description')}</p>

    {/* Variant selector */}
    <div class="flex justify-center gap-2 mb-6" role="group" aria-label="Badge variant">
      {variants.map((v, i) => (
        <button
          type="button"
          data-variant={v.id}
          data-file={v.file}
          aria-pressed={i === 0 ? 'true' : 'false'}
          class:list={[
            'badge-variant-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors cursor-pointer',
            i === 0
              ? 'bg-yellow-400 text-gray-950'
              : 'bg-gray-800 text-gray-300 hover:bg-gray-700',
          ]}
        >
          {v.label}
        </button>
      ))}
    </div>

    {/* Badge preview — single container, swapped via JS */}
    <div class="mb-8">
      <div
        id="badge-preview"
        class="inline-flex items-center justify-center rounded-lg px-8 py-5 bg-black transition-colors"
        data-bg-colour="bg-black"
        data-bg-black="bg-gray-100"
        data-bg-white="bg-gray-800"
      >
        <img id="badge-img" src="/badge_colour.svg" alt="We are Friendly" class="h-12" />
      </div>
    </div>

    {/* Copy buttons + download */}
    <div class="flex flex-col sm:flex-row flex-wrap gap-3 justify-center items-stretch sm:items-center max-w-xs sm:max-w-none mx-auto">
      <button
        type="button"
        data-action="copy-html"
        data-site-url={siteUrl}
        class="copy-btn inline-flex items-center justify-center gap-2 bg-gray-800 hover:bg-gray-700 text-yellow-100 px-5 py-2.5 rounded-lg font-medium text-sm transition-colors cursor-pointer sm:min-w-44"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        {t(lang, 'badge.copy.html')}
      </button>
      <button
        type="button"
        data-action="copy-markdown"
        data-site-url={siteUrl}
        class="copy-btn inline-flex items-center justify-center gap-2 bg-gray-800 hover:bg-gray-700 text-yellow-100 px-5 py-2.5 rounded-lg font-medium text-sm transition-colors cursor-pointer sm:min-w-44"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 208 128" fill="currentColor"><path d="M30 98V30l36 36 36-36v68h-20V59.6l-16 16-16-16V98H30zm125.2 2.4L122 65h25V30h20v35h25l-36.8 35.4z"/></svg>
        {t(lang, 'badge.copy.markdown')}
      </button>
      <a
        data-action="download"
        href="/badge_colour.svg"
        download="friendly-manifesto-badge.svg"
        class="inline-flex items-center justify-center gap-2 bg-yellow-500 hover:bg-yellow-400 text-gray-950 px-5 py-2.5 rounded-lg font-medium text-sm transition-colors sm:min-w-44"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        {t(lang, 'badge.download')}
      </a>
    </div>
    <div id="copy-status" class="sr-only" aria-live="polite"></div>
  </div>
</section>

<script>
  let activeFile = 'badge_colour.svg';

  const preview = document.getElementById('badge-preview')!;
  const badgeImg = document.getElementById('badge-img') as HTMLImageElement;
  const allBgs = ['bg-black', 'bg-gray-100', 'bg-gray-800'];

  // Variant switching
  document.querySelectorAll<HTMLButtonElement>('.badge-variant-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const variant = btn.dataset.variant!;
      activeFile = btn.dataset.file!;

      // Update button styles and aria-pressed
      document.querySelectorAll('.badge-variant-btn').forEach((b) => {
        b.classList.remove('bg-yellow-400', 'text-gray-950');
        b.classList.add('bg-gray-800', 'text-gray-300');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.remove('bg-gray-800', 'text-gray-300');
      btn.classList.add('bg-yellow-400', 'text-gray-950');
      btn.setAttribute('aria-pressed', 'true');

      // Swap image and background
      badgeImg.src = `/${activeFile}`;
      preview.classList.remove(...allBgs);
      preview.classList.add(preview.dataset[`bg${variant.charAt(0).toUpperCase() + variant.slice(1)}`]!);

      // Update download link
      const dl = document.querySelector<HTMLAnchorElement>('[data-action="download"]');
      if (dl) {
        dl.href = `/${activeFile}`;
      }
    });
  });

  // Copy buttons
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const action = btn.dataset.action;
      const siteUrl = btn.dataset.siteUrl;
      if (!action || !siteUrl) return;

      const badgeUrl = `${siteUrl}/${activeFile}`;
      const alt = 'We are Friendly - The Friendly Manifesto';
      const text = action === 'copy-html'
        ? `<a href="${siteUrl}"><img src="${badgeUrl}" alt="${alt}" /></a>`
        : `[![${alt}](${badgeUrl})](${siteUrl})`;

      await navigator.clipboard.writeText(text);
      const original = btn.innerHTML;
      btn.textContent = 'Copied!';
      btn.classList.add('bg-emerald-600');
      const status = document.getElementById('copy-status');
      if (status) status.textContent = 'Copied to clipboard';
      setTimeout(() => {
        btn.innerHTML = original;
        btn.classList.remove('bg-emerald-600');
        if (status) status.textContent = '';
      }, 2000);
    });
  });
</script>
