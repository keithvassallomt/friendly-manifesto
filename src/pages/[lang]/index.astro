---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Badge from '../../components/Badge.astro';
import ReadingMode from '../../components/ReadingMode.astro';
import { getCollection, render } from 'astro:content';
import { languages, t, type Lang } from '../../i18n/config';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };

const allManifestos = await getCollection('manifesto');
const entry = allManifestos.find((e) => e.data.lang === lang);

if (!entry) {
  return Astro.redirect('/en/');
}

const { Content } = await render(entry);
---

<Layout title={t(lang, 'site.title')} description={t(lang, 'site.description')} lang={lang}>
  <Header lang={lang} />

  <main id="main-content" class="flex-1">
    <!-- Hero + TL;DR: fills viewport below sticky header -->
    <section class="hero-viewport bg-linear-to-b from-gray-950 to-gray-900 text-yellow-50 flex flex-col justify-center">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <img src="/friendly.svg" alt="Friendly Manifesto logo" class="w-24 h-24 sm:w-28 sm:h-28 mx-auto mb-4" />
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-3 text-yellow-300">
          {entry.data.title}
        </h1>
        <p class="text-yellow-500 text-sm font-mono">
          v{entry.data.version} &middot; {entry.data.date}
        </p>
        <p class="mt-4 text-yellow-100 text-lg max-w-2xl mx-auto leading-relaxed">
          {entry.data.description}
        </p>
        <div class="mt-8 grid gap-3 max-w-2xl mx-auto text-left text-sm sm:text-base">
          <div class="bg-yellow-400/10 border border-yellow-400/20 rounded-lg px-5 py-3">
            <strong class="text-yellow-300">Software Developers</strong>
            <span class="text-yellow-100"> commit to building honest, secure, and respectful software that does not exploit its Users.</span>
          </div>
          <div class="bg-yellow-400/10 border border-yellow-400/20 rounded-lg px-5 py-3">
            <strong class="text-yellow-300">Gatekeepers</strong>
            <span class="text-yellow-100"> commit to distributing software fairly, transparently, and without subjective or ideological gatekeeping.</span>
          </div>
          <div class="bg-yellow-400/10 border border-yellow-400/20 rounded-lg px-5 py-3">
            <strong class="text-yellow-300">Users</strong>
            <span class="text-yellow-100"> commit to engaging with developers and communities respectfully, in good faith, and with realistic expectations.</span>
          </div>
        </div>
        <a href="#table-of-contents" class="scroll-cta mt-8 inline-flex flex-col items-center gap-1 text-yellow-400/60 hover:text-yellow-300 transition-colors" aria-label="Scroll down to read">
          <span class="text-xs uppercase tracking-widest">Read the manifesto</span>
          <svg class="w-5 h-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </section>

    <!-- Manifesto content -->
    <article class="max-w-4xl mx-auto px-6 py-12 sm:py-16">
      <div class="prose prose-lg prose-manifesto max-w-none">
        <Content />
      </div>
    </article>

    <!-- Badge -->
    <Badge lang={lang} />
  </main>

  <Footer lang={lang} />
  <ReadingMode />
</Layout>
