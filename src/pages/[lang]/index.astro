---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Badge from '../../components/Badge.astro';
import { getCollection, render } from 'astro:content';
import { languages, t, type Lang } from '../../i18n/config';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };

const allManifestos = await getCollection('manifesto');
const entry = allManifestos.find((e) => e.data.lang === lang);

if (!entry) {
  return Astro.redirect('/en/');
}

const { Content } = await render(entry);
---

<Layout title={t(lang, 'site.title')} description={t(lang, 'site.description')} lang={lang}>
  <Header lang={lang} />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-gradient-to-b from-gray-950 to-gray-900 text-yellow-50 py-16 sm:py-24">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-4 text-yellow-300">
          {entry.data.title}
        </h1>
        <p class="text-yellow-500 text-lg font-mono">
          v{entry.data.version} &middot; {entry.data.date}
        </p>
        <p class="mt-6 text-yellow-100 text-lg max-w-2xl mx-auto leading-relaxed">
          {entry.data.description}
        </p>
      </div>
    </section>

    <!-- Manifesto content -->
    <article class="max-w-4xl mx-auto px-6 py-12 sm:py-16">
      <div class="prose prose-lg prose-manifesto max-w-none">
        <Content />
      </div>
    </article>

    <!-- Badge -->
    <Badge lang={lang} />
  </main>

  <Footer lang={lang} />
</Layout>
