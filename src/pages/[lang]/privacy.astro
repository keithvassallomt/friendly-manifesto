---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { languages, t, type Lang } from '../../i18n/config';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---

<Layout title={t(lang, 'privacy.title')} description={t(lang, 'privacy.heading')} lang={lang}>
  <Header lang={lang} />

  <main id="main-content" class="flex-1">
    <article class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-950 mb-8">{t(lang, 'privacy.heading')}</h1>

      <div class="prose prose-lg max-w-none">
        <p>{t(lang, 'privacy.intro')}</p>

        <h2>{t(lang, 'privacy.noCollection.heading')}</h2>
        <p>{t(lang, 'privacy.noCollection.body')}</p>

        <h2>{t(lang, 'privacy.hosting.heading')}</h2>
        <p>
          {t(lang, 'privacy.hosting.body')}{' '}
          <a href="https://aws.amazon.com/privacy/" target="_blank" rel="noopener noreferrer">
            {t(lang, 'privacy.hosting.link')}
          </a>.
        </p>

        <h2>{t(lang, 'privacy.thirdParty.heading')}</h2>
        <p>{t(lang, 'privacy.thirdParty.body')}</p>

        <h2>{t(lang, 'privacy.changes.heading')}</h2>
        <p>{t(lang, 'privacy.changes.body')}</p>

        <p class="text-sm text-gray-500 mt-8">
          {t(lang, 'privacy.lastUpdated')}: 12 March 2026
        </p>
      </div>
    </article>
  </main>

  <Footer lang={lang} />
</Layout>
